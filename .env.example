# ─────────────────────────────────────────────────────────────────
# ravist-ig-publish — Environment Variables
# Copy to .env and fill in values
# See SETUP_PUBLISHING.md for step-by-step instructions
# ─────────────────────────────────────────────────────────────────

PORT=3004

# Optional: shared secret so only ravist-backend can call this service
SERVICE_API_KEY=

# ── Instagram Graph API credentials ───────────────────────────────
# Your Instagram Business Account numeric ID
# How to get: SETUP_PUBLISHING.md → Step 5
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Long-lived Page Access Token (never expires)
# How to get: SETUP_PUBLISHING.md → Step 6
INSTAGRAM_PAGE_ACCESS_TOKEN=
